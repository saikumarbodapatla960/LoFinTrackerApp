<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="app_database.db"/>
        <exclude domain="database" path="app_database.db-wal"/>
        <exclude domain="database" path="app_database.db-shm"/>
        <!-- If you have DataStore preferences, you might also want to exclude them, e.g.: -->
        <!-- <exclude domain="sharedpref" path="settings.xml"/> -->
    </cloud-backup>
    <device-transfer>
        <!-- You might want to apply similar exclusions for device-to-device transfer as well -->
        <exclude domain="database" path="app_database.db"/>
        <exclude domain="database" path="app_database.db-wal"/>
        <exclude domain="database" path="app_database.db-shm"/>
    </device-transfer>
</data-extraction-rules>